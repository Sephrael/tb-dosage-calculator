{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src", "*.config.*"],
  "exclude": ["dist", "node_modules"]
}
